# =============================================================================
# DeepFace Environment Variables
# =============================================================================
# Copy this file to .env and fill in values. For the API, place .env in
# deepface/api/ or set variables before running. See docs/ENVIRONMENT.md for
# full documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Database backend: postgres, mongo, weaviate, neo4j, pgvector, pinecone
DEEPFACE_DATABASE_TYPE=postgres

# Primary connection: overrides type-specific vars below when set.
# Format depends on database_type (e.g. postgresql://user:pass@host:5432/db)
DEEPFACE_CONNECTION_DETAILS=

# Type-specific connection strings (used when DEEPFACE_CONNECTION_DETAILS not set)
# DEEPFACE_POSTGRES_URI=postgresql://user:pass@localhost:5432/deepface
# DEEPFACE_MONGO_URI=mongodb://localhost:27017/deepface
# DEEPFACE_WEAVIATE_URI=http://localhost:8080
# DEEPFACE_NEO4J_URI=bolt://localhost:7687
# DEEPFACE_PINECONE_API_KEY=<your-pinecone-api-key>

# -----------------------------------------------------------------------------
# Authentication (Bearer token - SQLite-backed)
# -----------------------------------------------------------------------------
# Auth is always enabled. Tokens are stored in a SQLite database. Add tokens with:
#   INSERT INTO api_tokens (name, token, status) VALUES ('my-team', 'secret', 'active');
# Mount the DB file into the container at /data/deepface.db in production.

# Path to SQLite token database (default: /data/deepface.db)
# TOKEN_DB_PATH=/data/deepface.db

# -----------------------------------------------------------------------------
# Model / Performance
# -----------------------------------------------------------------------------
# Comma-separated models to load at startup (reduces first-request latency)
DEEPFACE_FACE_RECOGNITION_MODELS=VGG-Face,Facenet
DEEPFACE_FACE_DETECTION_MODELS=mtcnn

# -----------------------------------------------------------------------------
# Storage / Paths
# -----------------------------------------------------------------------------
# Base directory for model weights (default: user home)
# DEEPFACE_HOME=~/.deepface

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Python logging level (e.g. 10=DEBUG, 20=INFO, 30=WARNING)
# DEEPFACE_LOG_LEVEL=20

# -----------------------------------------------------------------------------
# Optional: Database-specific (when using those backends)
# -----------------------------------------------------------------------------
# Weaviate (fallback URL if not in DEEPFACE_CONNECTION_DETAILS)
# DEEPFACE_WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=<api-key-if-weaviate-auth-enabled>
# WEAVIATE_HNSW_M=16

# Pinecone (only DEEPFACE_PINECONE_API_KEY is required; others have defaults)
# DEEPFACE_PINECONE_CLOUD=aws
# DEEPFACE_PINECONE_REGION=us-east-1

# -----------------------------------------------------------------------------
# Optional: Face detector tuning (core library)
# -----------------------------------------------------------------------------
# yunet_score_threshold=0.9
# YOLO_MIN_DETECTION_CONFIDENCE=0.25
# MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.7
# MEDIAPIPE_MODEL_SELECTION=0
# CENTERFACE_THRESHOLD=0.35
